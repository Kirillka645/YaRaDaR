# Server
PORT=8080

# Optional: protect public API (leave empty for local open access)
API_TOKEN=

# Official / licensed demand provider — NEVER commit real secrets
OFFICIAL_DEMAND_URL=
OFFICIAL_DEMAND_TOKEN=

# Cache TTL for normalized zones (seconds)
CACHE_TTL_SECONDS=60

# Set true only for integration tests — emits is_demo=true zones from backend
DEMO_ZONES_VIA_BACKEND=false
